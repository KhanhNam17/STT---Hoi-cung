# .env.example — copy thành .env và điền giá trị
#
# Smart Meeting (Live Mode only) — Sortformer ONLY.
# Không dùng diart, pyannote, NPU server.

# ────────────────────────────────────────────────────────────────────
# BẮT BUỘC: HuggingFace token (NeMo tải Sortformer model từ HF Hub)
# ────────────────────────────────────────────────────────────────────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
# Lấy token: https://huggingface.co/settings/tokens

# ────────────────────────────────────────────────────────────────────
# Windows: chống NeMo silent-crash do OpenMP conflict
# ────────────────────────────────────────────────────────────────────
# NeMo (qua numpy MKL + torch) load 2 OpenMP runtime → process abort.
# Đặt biến này → Intel MKL warn thay vì abort. Bắt buộc cho Windows.
KMP_DUPLICATE_LIB_OK=TRUE

# ────────────────────────────────────────────────────────────────────
# Tắt hoàn toàn Sortformer (debugging only)
# ────────────────────────────────────────────────────────────────────
# Khi NeMo lỗi nặng và bạn vẫn muốn test STT live → SORTFORMER_DISABLED=1.
# App sẽ chạy nhưng KHÔNG phân tách người nói (mọi turn = "Người nói 1").
# SORTFORMER_DISABLED=1

# ────────────────────────────────────────────────────────────────────
# Live STT (Zipformer streaming model) — đường dẫn ONNX
# ────────────────────────────────────────────────────────────────────
LIVE_MODEL_DIR=models/zipformer
LIVE_SAMPLE_RATE=16000
LIVE_CHUNK_FRAMES=3200      # 200ms / chunk

# ────────────────────────────────────────────────────────────────────
# Verbose log (debug)
# ────────────────────────────────────────────────────────────────────
# LIVE_DEBUG=1        # in trạng thái mỗi giây trong console
# FINALIZE_DEBUG=1    # in full_text + 6 turn đầu sau finalize
