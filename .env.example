# .env.example — copy to .env và điền giá trị thật
#
# Bắt buộc cho cả 2 backend diarization
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
# Lấy token: https://huggingface.co/settings/tokens
# Đồng ý điều khoản trên:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
#   https://huggingface.co/pyannote/embedding

# ────────────────────────────────────────────────────────────────────
# DIARIZATION BACKEND cho Live Mode
# ────────────────────────────────────────────────────────────────────
# "npu"   — gửi 60s audio qua HTTP đến Nexa NPU server (cần Nexa chạy ngoài).
#           Phù hợp khi có máy Snapdragon + Nexa SDK installed.
#
# "diart" — chạy local bằng diart Python library (pyannote-based streaming).
#           Latency ~500ms, không cần server ngoài, portable mọi máy có HF_TOKEN.
#           BẬT phương án này cho dev/demo trên laptop thường.
DIARIZATION_BACKEND=diart

# ── Tinh chỉnh diart (chỉ khi DIARIZATION_BACKEND=diart) ────────────
# Latency tối thiểu (giây) — càng thấp càng phản hồi nhanh, càng dễ flicker
DIART_LATENCY=0.5
DIART_STEP=0.5            # bước trượt
DIART_DURATION=5.0        # cửa sổ phân tích
DIART_TAU_ACTIVE=0.5      # ngưỡng phát hiện giọng nói
DIART_RHO_UPDATE=0.3
DIART_DELTA_NEW=1.0       # ngưỡng tạo speaker mới — tăng → ít speakers hơn

# ── NPU backend config (chỉ khi DIARIZATION_BACKEND=npu) ─────────────
NPU_API_URL=http://127.0.0.1:18182/v1/audio/diarize

# ────────────────────────────────────────────────────────────────────
# OFFLINE diarization (Batch Mode) — chọn model cho core/diarizer.py
# ────────────────────────────────────────────────────────────────────
# community-1 (mặc định, tốt nhất) | speaker-diarization-3.1 (legacy) | precision-2 (cloud)
DIARIZATION_MODEL=pyannote/speaker-diarization-community-1

# PYANNOTE_API_KEY chỉ cần nếu dùng precision-2 (cloud)
# PYANNOTE_API_KEY=

# ────────────────────────────────────────────────────────────────────
# Live Mode — STT (Zipformer)
# ────────────────────────────────────────────────────────────────────
LIVE_MODEL_DIR=models/zipformer
LIVE_SAMPLE_RATE=16000
LIVE_CHUNK_FRAMES=3200
